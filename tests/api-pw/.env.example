# Copy to .env (or export these) before running the DAM API suite.
# The DAM API is guarded by Passport (auth:api) AND UnoPim's API-scope
# middleware, so a bare passport client is not enough — you need an admin-owned
# password-grant client PLUS a matching api_keys row, or authenticated requests
# return 500. Create both at once in the UnoPim admin:
#   Configuration -> Integrations -> API Keys -> Create
#     - assign to an admin user, set Permission Type = All,
#     - Save, then Generate to reveal the client id & secret.
# Then fill in the id/secret below.

# Target instance
BASE_URL=http://127.0.0.1:8000

# OAuth2 password grant
OAUTH_TOKEN_URL=/oauth/token
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=*

# Admin credentials the token is minted for
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=admin123

# Alternatively, supply a pre-minted bearer token and the password grant is skipped.
# NOTE: when set, the OAuth token-lifecycle tests in 01 self-skip — prefer the
# client credentials above for a zero-skip run.
# API_TOKEN=eyJ0eXAiOiJKV1Qi...

# Locale used by locale-aware endpoints (properties)
API_LOCALE=en_US

# --- Optional: set ALL of these for a zero-skip run -------------------------
# Seed data the REST API cannot create for itself; the dependent tests self-skip
# when unset. See README → "Environment variables".
#
# A known tag id  → positive tag fetch (06)
# TAG_ID=
# A known asset<->resource mapping id → positive linked-resource fetch (09)
# LINKED_RESOURCE_ID=
# Token for a custom-role admin with limited directory grants → 403 tests (10)
# SCOPED_API_TOKEN=
# An asset / directory that the scoped user must NOT access (10)
# DENIED_ASSET_ID=
# DENIED_DIR_ID=

# Flag responses slower than this (ms) in the report attachments
SLOW_RESPONSE_MS=2000

# Raise worker count only against a multi-process server (php-fpm), not artisan serve
# WORKERS=4
