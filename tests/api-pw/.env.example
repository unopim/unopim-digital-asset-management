# Copy to .env (or export these) before running the DAM API suite.
# The suite is guarded by Laravel Passport (auth:api), so it needs an OAuth2
# password-grant client. Create one in your UnoPim install with:
#   php artisan passport:client --password
# then fill in the id/secret it prints below.

# Target instance
BASE_URL=http://127.0.0.1:8000

# OAuth2 password grant
OAUTH_TOKEN_URL=/oauth/token
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=*

# Admin credentials the token is minted for
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=admin123

# Alternatively, supply a pre-minted bearer token and the password grant is skipped:
# API_TOKEN=eyJ0eXAiOiJKV1Qi...

# Locale used by locale-aware endpoints (properties)
API_LOCALE=en_US

# Flag responses slower than this (ms) in the report attachments
SLOW_RESPONSE_MS=2000

# Raise worker count only against a multi-process server (php-fpm), not artisan serve
# WORKERS=4
